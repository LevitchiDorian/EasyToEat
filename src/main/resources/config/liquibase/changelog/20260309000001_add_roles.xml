        <sql>INSERT INTO jhi_authority (name) VALUES ('ROLE_MANAGER') ON CONFLICT DO NOTHING;</sql>
        <sql>INSERT INTO jhi_authority (name) VALUES ('ROLE_STAFF') ON CONFLICT DO NOTHING;</sql>
    </changeSet>

</databaseChangeLog>
